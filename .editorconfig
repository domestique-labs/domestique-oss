# https://editorconfig.org — consistent editor defaults across the team.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 99

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
# Markdown uses trailing whitespace for hard line breaks.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
