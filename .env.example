# Domestique Environment Configuration
# Copy this file to .env and fill in your values

# === LLM Provider API Keys (centrally managed) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=

# === Domestique Settings ===
# DOMESTIQUE_DEBUG=false
# DOMESTIQUE_FAIL_MODE=closed
# DOMESTIQUE_PORT=8000
# DOMESTIQUE_WORKERS=4

# === Detection Thresholds ===
# DOMESTIQUE_PII_CONFIDENCE_THRESHOLD=0.7
# DOMESTIQUE_ENABLE_PII_DETECTION=true
# DOMESTIQUE_ENABLE_SECRET_DETECTION=true
# DOMESTIQUE_ENABLE_SEMANTIC_DETECTION=true
# DOMESTIQUE_ENABLE_LOCAL_LLM=false

# === Local LLM (Tier 3 — second-pass classifier) ===
# Presets: minimal, balanced, quality, legacy-cpu
# DOMESTIQUE_LOCAL_LLM_PRESET=balanced
# DOMESTIQUE_LOCAL_LLM_MODEL=gemma4:e2b
# DOMESTIQUE_LOCAL_LLM_URL=http://localhost:11434
# DOMESTIQUE_LOCAL_LLM_TIMEOUT_S=5.0

# === Auth ===
# DOMESTIQUE_REQUIRE_AUTH=true
# DOMESTIQUE_ALLOWED_API_KEYS=key1,key2,key3
