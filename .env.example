# LLMGuard Environment Configuration
# Copy this file to .env and fill in your values

# === LLM Provider API Keys (centrally managed) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=

# === LLMGuard Settings ===
# LLMGUARD_DEBUG=false
# LLMGUARD_FAIL_MODE=closed
# LLMGUARD_PORT=8000
# LLMGUARD_WORKERS=4

# === Detection Thresholds ===
# LLMGUARD_PII_CONFIDENCE_THRESHOLD=0.7
# LLMGUARD_ENABLE_PII_DETECTION=true
# LLMGUARD_ENABLE_SECRET_DETECTION=true
# LLMGUARD_ENABLE_SEMANTIC_DETECTION=true
# LLMGUARD_ENABLE_LOCAL_LLM=false

# === Local LLM (Tier 3 — second-pass classifier) ===
# Presets: minimal, balanced, quality, legacy-cpu
# LLMGUARD_LOCAL_LLM_PRESET=balanced
# LLMGUARD_LOCAL_LLM_MODEL=gemma4:e2b
# LLMGUARD_LOCAL_LLM_URL=http://localhost:11434
# LLMGUARD_LOCAL_LLM_TIMEOUT_S=5.0

# === Auth ===
# LLMGUARD_REQUIRE_AUTH=true
# LLMGUARD_ALLOWED_API_KEYS=key1,key2,key3
